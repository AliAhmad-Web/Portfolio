# Frontend (Vite) — copy to `.env.local` for local development
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# Production only (Vercel): absolute URL of the deployed Express API including `/api/v1`
# Leave unset locally — Vite proxies `/api` → http://localhost:5000
# Example: VITE_API_BASE_URL=https://your-api.onrender.com/api/v1
# VITE_API_BASE_URL=
