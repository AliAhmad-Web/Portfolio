# Server
NODE_ENV=development
PORT=5000

# Frontend (comma-separated for multiple origins)
# Local: http://localhost:5173
# Production: https://your-app.vercel.app (add custom domain too if you have one)
CLIENT_URL=http://localhost:5173

# Cookies
COOKIE_SECRET=replace-with-a-long-random-secret

# JWT
JWT_ACCESS_COOKIE=access_token
JWT_REFRESH_COOKIE=refresh_token
JWT_EXPIRES_IN=7d

# Auth redirects (must be allowed in Supabase Auth URL config)
AUTH_VERIFY_EMAIL_URL=http://localhost:5173/auth/verify-email
AUTH_RESET_PASSWORD_URL=http://localhost:5173/auth/reset-password
REQUIRE_EMAIL_VERIFICATION=true

# Supabase — find these in Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Must be the service_role secret (NOT the anon key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase JWT Secret — Project Settings > API > JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret

# First admin user (used by: npm run seed:admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=Portfolio Admin

# Google reCAPTCHA v3 — https://www.google.com/recaptcha/admin
# Secret key stays on the server only (never expose to the frontend)
RECAPTCHA_SECRET_KEY=your-recaptcha-v3-secret-key
RECAPTCHA_MIN_SCORE=0.5
# Set to false to temporarily disable verification
RECAPTCHA_ENABLED=true

# Login rate limiting (failed attempts only)
# Max failed logins allowed per IP+email within the window
LOGIN_RATE_LIMIT_MAX=5
# Window in milliseconds (default: 15 minutes)
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Resend email notifications — https://resend.com
RESEND_API_KEY=re_xxxxxxxx
# Use onboarding@resend.dev for testing, or your verified domain in production
RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>
# Admin inbox that receives contact form alerts (falls back to ADMIN_EMAIL)
RESEND_TO_EMAIL=admin@example.com
RESEND_ENABLED=true
