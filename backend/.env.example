 # Server
NODE_ENV=development
PORT=5000

# Frontend (comma-separated for multiple origins)
CLIENT_URL=http://localhost:5173

# Cookies
COOKIE_SECRET=replace-with-a-long-random-secret

# JWT
JWT_ACCESS_COOKIE=access_token
JWT_REFRESH_COOKIE=refresh_token
JWT_EXPIRES_IN=7d

# Auth redirects (must be allowed in Supabase Auth URL config)
AUTH_VERIFY_EMAIL_URL=http://localhost:5173/auth/verify-email
AUTH_RESET_PASSWORD_URL=http://localhost:5173/auth/reset-password
REQUIRE_EMAIL_VERIFICATION=true

# Supabase — find these in Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase JWT Secret — Project Settings > API > JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret
